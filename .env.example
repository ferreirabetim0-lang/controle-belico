# ============================
# CONTROLE BÉLICO — ENV EXAMPLE
# Copie este arquivo para .env e preencha os valores
# ============================

# Database
DATABASE_URL="postgresql://controlebelico:strongpassword@localhost:5432/controlebelico"
POSTGRES_USER=controlebelico
POSTGRES_PASSWORD=strongpassword
POSTGRES_DB=controlebelico

# JWT
JWT_SECRET=seu_jwt_secret_super_seguro_aqui
JWT_REFRESH_SECRET=seu_refresh_secret_super_seguro_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=controlebelico
MINIO_ROOT_PASSWORD=miniopassword
MINIO_BUCKET=controle-belico

# Redis
REDIS_URL=redis://localhost:6379

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# WhatsApp (Evolution API)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@controlebelico.com.br
